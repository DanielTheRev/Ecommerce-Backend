{
	"name": "electro-hub-backend",
	"version": "1.0.0",
	"description": "Backend para Electro Hub con Node.js, TypeScript, Express y Mongoose",
	"main": "dist/index.js",
	"scripts": {
		"dev": "nodemon src/index.ts",
		"start": "node dist/index.js",
		"build": "tsc && tsc-alias",
		"build:watch": "tsc --watch",
		"seedProducts": "ts-node -r tsconfig-paths/register src/scripts/seedData.ts",
		"seedInitialConfig": "ts-node -r tsconfig-paths/register src/scripts/seedInitialConfig.ts",
		"seedAdminUsers": "ts-node -r tsconfig-paths/register src/scripts/seedAdminUsers.ts",
		"seedShippingOptions": "ts-node -r tsconfig-paths/register src/scripts/seedShippingOptions.ts",
		"seedPaymentMethods": "ts-node -r tsconfig-paths/register src/scripts/seedPaymentMethods.ts",
		"TestResendAPI": "ts-node -r tsconfig-paths/register src/scripts/resendTest.ts"
	},
	"keywords": [
		"nodejs",
		"typescript",
		"express",
		"mongoose"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"bcryptjs": "^3.0.2",
		"cloudinary": "^2.9.0",
		"cookie": "^1.1.1",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"datauri": "^4.1.0",
		"dotenv": "^16.3.1",
		"express": "^5.2.1",
		"google-auth-library": "^10.2.0",
		"helmet": "^7.1.0",
		"jsonwebtoken": "^9.0.2",
		"mongoose": "^8.0.3",
		"morgan": "^1.10.0",
		"multer": "^2.0.2",
		"resend": "^4.7.0",
		"slugify": "^1.6.6",
		"socket.io": "^4.8.1",
		"ts-lib": "^0.0.5",
		"ts-node": "^10.9.1",
		"tslib": "^2.8.1",
		"ualabis-nodejs": "^1.0.1",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@types/cookie-parser": "^1.4.9",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/morgan": "^1.9.9",
		"@types/multer": "^2.0.0",
		"@types/node": "^20.10.4",
		"@types/socket.io": "^3.0.2",
		"nodemon": "^3.0.2",
		"ts-node": "^10.9.1",
		"tsc-alias": "^1.8.16",
		"tsconfig-paths": "^3.14.0",
		"typescript": "^5.3.3"
	}
}
